      "type": "section-custom-code",
      "name": "Custom code",
      "settings": {
        "code": "<section id=\"shopify-section-jimfambiz__video_with_stats\" class=\"shopify-section section\"> \n\n\n<style data-shopify=\"\">\n #shopify-section-jimfambiz__video_with_stats .custom-bg{\n  background-color:#f7f7f7;\n\n }\n  .content-row-customvideogridpuqkxr {\n    display: flex;\n    background-color: #ffffff;\n    border-radius: 12px;\n    overflow: hidden;\n    border: 1px solid #E0E0E0;\n    padding: 24px;\n  }\n\n  .image-column-customvideogridpuqkxr {\n    width: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 0px;\n  }\n\n  .image-wrapper-customvideogridpuqkxr {\n    width: 100%;\n    height: 100%;\n    min-height: 400px;\n    display: flex;\n    align-items: center;\n    justify-content: center;}\n\n  .image-wrapper-customvideogridpuqkxr img {\n    width: 100%;\n    height: 100%;\n    object-fit: contain;\n    border-radius: 4px;\n    display:block;\n  }\n\n  .image-placeholder-customvideogridpuqkxr {\n    width: 100%;\n    height: 100%;\n    background-color: #f4f4f4;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-radius: 4px;\n  }\n\n  .image-placeholder-customvideogridpuqkxr svg {\n    width: 100%;\n    height: 100%;\n    max-width: 200px;\n    max-height: 200px;\n    opacity: 0.5;\n  }\n\n  .text-column-customvideogridpuqkxr {\n    width: 50%;\n    display: flex;\n    align-items: center;\n    padding: 0px;\n  }\n\n  .text-content-customvideogridpuqkxr {\n    width: 100%;\n    display: flex;\n    flex-direction: column;\n    gap: 50px;\n        padding: 0px 60px;\n  }\n\n  .title-section-customvideogridpuqkxr {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n\n  .title-section-customvideogridpuqkxr h2 {\n    margin: 0;\n    \n    color: #000000;\n        line-height: normal;\n  }\n\n  .title-section-customvideogridpuqkxr .rich-text {\n    color: #1c1c1c;\n  }\n\n  .percentage-section-customvideogridpuqkxr {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .percentage-circle-customvideogridpuqkxr {\n    position: relative;\n    width: 90px;\n    height: 90px;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 24px;\n    font-weight: 600;\n    color: #1c1c1c;\n    background: conic-gradient(\n      from 0deg,\n      #f7f7f7 0deg,\n      #f7f7f7 360deg\n    );}\n\n  .percentage-circle-customvideogridpuqkxr::before {\n    content: '';\n    position: absolute;\n    top: 8px;\n    left: 8px;\n    right: 8px;\n    bottom: 8px;\n    background-color: #ffffff;\n    border-radius: 50%;\n    z-index: 1;\n  }\n\n  .percentage-text-customvideogridpuqkxr {\n    position: relative;\n    z-index: 2;\n  }\n\n  .percentage-description-customvideogridpuqkxr {\n    flex: 1;\n    color: #1c1c1c;}\n\n  .additional-content-customvideogridpuqkxr {\n    padding-left: 50px;}\n\n  .additional-content-customvideogridpuqkxr p {\n    margin: 0 0 25px 0;\n    color: #1c1c1c;\n  }\n\n  .additional-content-customvideogridpuqkxr p:last-child {\n    margin-bottom: 0;\n  }\n\n  .additional-content-customvideogridpuqkxr p:empty {\n    height: 25px;\n  }\n\n  @media screen and (max-width: 768px) {\n     \n      .text-content-customvideogridpuqkxr {\n \n        padding: 0px;\n  }\n\n    .section-spacing-customvideogridpuqkxr {\n      padding: 40px 0;\n    }\n\n    .container-customvideogridpuqkxr {\n      padding: 0 15px;\n    }\n\n    .content-row-customvideogridpuqkxr {\n      flex-direction: column;min-height: auto;\n      padding: 15px 15px 25px 15px;\n    }\n\n    .image-column-customvideogridpuqkxr,\n    .text-column-customvideogridpuqkxr {\n      width: 100%;\n    }\n\n    .image-wrapper-customvideogridpuqkxr {\n      min-height: auto;\n    }\n\n    .text-column-customvideogridpuqkxr {\n      padding: 40px 30px;\n    }\n\n    .text-content-customvideogridpuqkxr {\n      gap: 35px;\n    }\n\n    .percentage-section-customvideogridpuqkxr {\n      \n      align-items: center;\n      gap: 15px;\n    }\n\n    .additional-content-customvideogridpuqkxr {\n      padding-left: 0px;\n    }\n     .text-column-customvideogridpuqkxr {\n     padding: 0px 0px;\n        padding-top: 30px;\n    }\n\n.f-20 {\n   font-size:20px;\n}\n  }\n\n  @media screen and (max-width: 480px) {\n    .text-column-customvideogridpuqkxr {\n     padding: 0px 0px;\n        padding-top: 30px;\n    }\n\n    .percentage-circle-customvideogridpuqkxr {\n      width: 70px;\n      height: 70px;\n      font-size: 20px;\n    }\n\n    .percentage-circle-customvideogridpuqkxr::before {\n      top: 6px;\n      left: 6px;\n      right: 6px;\n      bottom: 6px;\n    }\n  }\n</style>\n\n<progress-animation-jimfambiz>\n  <div class=\"section-spacing custom-bg\">\n  <div class=\"container\"> \n    <div class=\"content-row-customvideogridpuqkxr\">\n      <div class=\"image-column-customvideogridpuqkxr\">\n        <div class=\"image-wrapper-customvideogridpuqkxr\">\n          \n            <img src=\"https://www.optivesportswear.com/cdn/shop/files/Optive_Sportswear_Redesign_Frame_39973.jpg?v=1756378763&width=600\" alt=\"JIMFAMBIZ Wear\" loading=\"lazy\" width=\"1468\" height=\"970\">\n          \n        </div>\n      </div>\n\n      <div class=\"text-column-customvideogridpuqkxr\">\n        <div class=\"text-content-customvideogridpuqkxr\">\n          \n            <div class=\"title-section-customvideogridpuqkxr\">\n              \n                <h2 class=\"h2\" style=\"margin-top:0px;\">Warum JIMFAMBIZ Wear einen Unterschied macht?</h2>\n              \n              \n                <div class=\"rich-text f-16\"><p><strong>Unser Versprechen an dich:</strong> It's not just how it looks, it's how it makes you feel.</p></div>\n              \n            </div>\n          \n\n          \n            <div class=\"percentage-section-customvideogridpuqkxr\">\n              <div class=\"percentage-circle-customvideogridpuqkxr\" data-percentage=\"93\" style=\"background: conic-gradient(rgb(212, 237, 218) 0deg, rgb(212, 237, 218) 334.8deg, rgb(247, 247, 247) 334.8deg, rgb(247, 247, 247) 360deg);\">\n                <span class=\"percentage-text-customvideogridpuqkxr f-20\">93%</span>\n              </div>\n              \n                <div class=\"percentage-description-customvideogridpuqkxr f-16\"><p><strong>der Kunden berichten,</strong> dass sie sich in JIMFAMBIZ Wear deutlich wohler fühlen als in ihrer bisherigen Sportswear.</p></div>\n              \n            </div>\n          \n\n          \n            <div class=\"additional-content-customvideogridpuqkxr f-16\">\n              <p><strong>Quality first</strong> Unsere Materialien fühlen sich nicht nur weich an, sondern halten auch lange und bleiben in Form – ganz egal, wie oft du sie trägst.</p><p><strong>Form follows function</strong> Unsere Schnitte sind gemacht für Bewegung. Kein Zwicken, kein Verrutschen – nur Komfort, der sich deinem Alltag anpasst.<br><br><strong>Designed for every body</strong> JIMFAMBIZ Wear passt sich dir an, nicht umgekehrt. Für jede Figur, jede Größe, jedes Gefühl von Selbstbewusstsein.</p>\n            </div>\n          \n        </div>\n      </div>\n    </div>\n  </div>\n  </div>\n</progress-animation-jimfambiz>\n\n<script>\n  (function() {\n    class ProgressAnimationJimfambiz extends HTMLElement {\n      constructor() {\n        super();\n        this.hasAnimated = false;}\n\n      connectedCallback() {\n        this.setupIntersectionObserver();}\n\n      setupIntersectionObserver() {\n        const options = {\n          threshold: 0.5,\n          rootMargin: '0px 0px -50px 0px'\n        };\n\n        const observer = new IntersectionObserver((entries) => {\n          entries.forEach(entry => {\n            if (entry.isIntersecting && !this.hasAnimated) {\n              this.animateProgress();\n              this.hasAnimated = true;\n            }\n          });\n        }, options);\n\n        observer.observe(this);\n      }\n\n      animateProgress() {\n        const circle = this.querySelector('.percentage-circle-customvideogridpuqkxr');\n        if (!circle) return;\n\n        const percentage = parseInt(circle.dataset.percentage) || 0;\n        circle.style.background = `conic-gradient(\n          from 0deg,\n          #f7f7f7 0deg,\n          #f7f7f7 360deg\n        )`;\n\n        let currentPercentage = 0;\n        const increment = percentage / 60;\n        const duration = 2000;\n        const stepTime = duration / 60;\n\n        const timer = setInterval(() => {\n          currentPercentage += increment;\n          if (currentPercentage >= percentage) {\n            currentPercentage = percentage;\n            clearInterval(timer);\n          }\n\n          circle.style.background = `conic-gradient(\n            from 0deg,\n            #d4edda 0deg,\n            #d4edda ${currentPercentage * 3.6}deg,\n            #f7f7f7 ${currentPercentage * 3.6}deg,\n            #f7f7f7 360deg\n          )`;\n        }, stepTime);\n      }\n    }\n\n    customElements.define('progress-animation-jimfambiz', ProgressAnimationJimfambiz);\n  })();\n</script>\n\n\n</section>",
        "width": "wrapper",
        "color_scheme": "",
        "padding_top": 16,
        "padding_bottom": 27
      }
