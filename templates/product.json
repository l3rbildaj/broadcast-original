      "name": "Custom code",
      "settings": {
        "code": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Reviews</title>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n\n    body {\n      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n      background: #fff;\n      color: #111;\n      padding: 32px 24px;\n    }\n\n    /* ── Header ── */\n    .reviews-header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      margin-bottom: 24px;\n    }\n    .header-left {\n      display: flex;\n      align-items: center;\n      gap: 10px;\n    }\n    .stars-large {\n      display: flex;\n      gap: 2px;\n    }\n    .stars-large .star {\n      width: 22px;\n      height: 22px;\n      fill: #f5a623;\n    }\n    .review-count {\n      font-size: 15px;\n      font-weight: 600;\n      color: #111;\n      display: flex;\n      align-items: center;\n      gap: 4px;\n      cursor: pointer;\n    }\n    .review-count svg { width: 14px; height: 14px; fill: #111; }\n    .header-right {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n    }\n    .write-btn {\n      background: #fff;\n      border: 1.5px solid #111;\n      border-radius: 6px;\n      padding: 8px 18px;\n      font-size: 14px;\n      font-weight: 600;\n      cursor: pointer;\n      transition: background .15s;\n    }\n    .write-btn:hover { background: #f5f5f5; }\n    .filter-icon { cursor: pointer; opacity: .75; }\n    .filter-icon:hover { opacity: 1; }\n\n    /* ── Masonry Grid ── */\n    .reviews-grid {\n      columns: 6 180px;\n      column-gap: 12px;\n    }\n\n    /* ── Card ── */\n    .review-card {\n      break-inside: avoid;\n      margin-bottom: 12px;\n      background: #fff;\n      border-radius: 0;\n      overflow: hidden;\n      cursor: pointer;\n      position: relative;\n    }\n\n    /* Media container */\n    .card-media {\n      position: relative;\n      width: 100%;\n      overflow: hidden;\n    }\n    .card-media img {\n      width: 100%;\n      display: block;\n      object-fit: cover;\n    }\n\n    /* Play button overlay for videos */\n    .play-overlay {\n      position: absolute;\n      inset: 0;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      pointer-events: none;\n    }\n    .play-btn {\n      width: 52px;\n      height: 52px;\n      background: rgba(255,255,255,0.92);\n      border-radius: 50%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      box-shadow: 0 2px 8px rgba(0,0,0,0.18);\n    }\n    .play-btn svg {\n      width: 20px;\n      height: 20px;\n      fill: #111;\n      margin-left: 3px;\n    }\n\n    /* Card body */\n    .card-body {\n      padding: 10px 10px 12px;\n    }\n\n    .reviewer-row {\n      display: flex;\n      align-items: center;\n      gap: 5px;\n      margin-bottom: 2px;\n    }\n    .reviewer-name {\n      font-size: 13px;\n      font-weight: 600;\n      color: #111;\n    }\n    .verified-badge {\n      display: flex;\n      align-items: center;\n      gap: 3px;\n      font-size: 11px;\n      color: #555;\n    }\n    .verified-badge svg {\n      width: 13px;\n      height: 13px;\n      fill: #1a73e8;\n    }\n    .review-date {\n      font-size: 11px;\n      color: #888;\n      margin-bottom: 6px;\n    }\n    .stars-small {\n      display: flex;\n      gap: 1px;\n      margin-bottom: 6px;\n    }\n    .stars-small .star {\n      width: 14px;\n      height: 14px;\n      fill: #f5a623;\n    }\n    .stars-small .star.empty {\n      fill: #ddd;\n    }\n    .review-text {\n      font-size: 13px;\n      color: #222;\n      line-height: 1.45;\n      margin-bottom: 8px;\n    }\n    .product-label {\n      font-size: 11px;\n      color: #888;\n      margin-bottom: 2px;\n    }\n    .product-variant {\n      font-size: 11px;\n      color: #555;\n      margin-bottom: 8px;\n    }\n    .product-row {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      border-top: 1px solid #f0f0f0;\n      padding-top: 8px;\n    }\n    .product-thumb {\n      width: 40px;\n      height: 40px;\n      object-fit: cover;\n      border-radius: 4px;\n      flex-shrink: 0;\n    }\n    .product-name {\n      font-size: 11px;\n      color: #444;\n      line-height: 1.35;\n    }\n\n    /* Load more */\n    .load-more-wrap {\n      text-align: center;\n      margin-top: 24px;\n    }\n    .load-more-btn {\n      background: #fff;\n      border: 1.5px solid #111;\n      border-radius: 6px;\n      padding: 10px 32px;\n      font-size: 14px;\n      font-weight: 600;\n      cursor: pointer;\n      transition: background .15s;\n    }\n    .load-more-btn:hover { background: #f5f5f5; }\n\n    @media (max-width: 900px) {\n      .reviews-grid { columns: 3 160px; }\n    }\n    @media (max-width: 560px) {\n      .reviews-grid { columns: 2 140px; }\n    }\n  </style>\n</head>\n<body>\n\n  <!-- Header -->\n  <div class=\"reviews-header\">\n    <div class=\"header-left\">\n      <div class=\"stars-large\">\n        <svg viewBox=\"0 0 24 24\" class=\"star\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>\n        <svg viewBox=\"0 0 24 24\" class=\"star\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>\n        <svg viewBox=\"0 0 24 24\" class=\"star\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>\n        <svg viewBox=\"0 0 24 24\" class=\"star\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>\n        <svg viewBox=\"0 0 24 24\" class=\"star\" style=\"fill:url(#half) #ddd\"><defs><linearGradient id=\"half\"><stop offset=\"70%\" stop-color=\"#f5a623\"/><stop offset=\"70%\" stop-color=\"#ddd\"/></linearGradient></defs><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>\n      </div>\n      <div class=\"review-count\">\n        663 Bewertungen\n        <svg viewBox=\"0 0 24 24\"><path d=\"M7 10l5 5 5-5z\"/></svg>\n      </div>\n    </div>\n    <div class=\"header-right\">\n      <button class=\"write-btn\">Bewertung schreiben</button>\n      <svg class=\"filter-icon\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#111\" stroke-width=\"2\"><line x1=\"4\" y1=\"6\" x2=\"20\" y2=\"6\"/><line x1=\"8\" y1=\"12\" x2=\"16\" y2=\"12\"/><line x1=\"11\" y1=\"18\" x2=\"13\" y2=\"18\"/></svg>\n    </div>\n  </div>\n\n  <!-- Reviews Grid -->\n  <div class=\"reviews-grid\" id=\"reviewsGrid\"></div>\n\n  <div class=\"load-more-wrap\">\n    <button class=\"load-more-btn\">Mehr Bewertungen anzeigen</button>\n  </div>\n\n  <script>\n    const reviews = [\n      {\n        reviewer: \"Verena K.\", date: \"5/29/2026\", rating: 5,\n        text: \"Mega geile Farbe und sitzt alles super bequem 👍🏽☀️\",\n        variant: \"Rose Pink / M\",\n        product: \"DIVINE Scrunch Shorts - Rose Pink\",\n        mediaType: \"video\",\n        mediaUrl: \"https://images.loox.io/uploads/2026/5/28/OIzEepG0dR_UaoS2hWqx_orig.jpg\",\n        productThumb: \"https://cdn.shopify.com/s/files/1/0643/0736/4057/files/OPTIVE_DIVINE_ScrunchShorts_RosePink_3_x50.webp?v=1762626928\"\n      },\n      {\n        reviewer: \"Anna Q.\", date: \"5/20/2026\", rating: 5,\n        text: \"Ein Set zum verlieben 🫶🏼\\nSitzt gut, es rutscht nix (besonders die Hose bleibt an Ort und Stelle)\\nIch brauch noch mehr Farben 🥸🤓\",\n        variant: \"Bordeaux Red / M\",\n        product: \"UNITY V-Shape Scrunch Shorts - Bordeaux Red (Limited Edition)\",\n        mediaType: \"photo\",\n        mediaUrl: \"https://images.loox.io/uploads/2026/5/19/1EJNz-mO9.jpg\",\n        productThumb: \"https://cdn.shopify.com/s/files/1/0643/0736/4057/files/OPTIVE_UNITY_Scr