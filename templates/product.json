; i++) {\n        const cls = i <= rating ? 'star' : 'star empty';\n        html += `<svg viewBox=\"0 0 24 24\" class=\"${cls}\"><path d=\"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z\"/></svg>`;\n      }\n      html += '</div>';\n      return html;\n    }\n\n    function verifiedSVG() {\n      return `<svg viewBox=\"0 0 24 24\"><path d=\"M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z\" fill=\"none\" stroke=\"#1a73e8\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>`;\n    }\n\n    const grid = document.getElementById('reviewsGrid');\n\n    reviews.forEach(r => {\n      const card = document.createElement('div');\n      card.className = 'review-card';\n\n      const isVideo = r.mediaType === 'video';\n      const playBtn = isVideo ? `\n        <div class=\"play-overlay\">\n          <div class=\"play-btn\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\"/></svg>\n          </div>\n        </div>` : '';\n\n      card.innerHTML = `\n        <div class=\"card-media\">\n          <img src=\"${r.mediaUrl}\" alt=\"Review by ${r.reviewer}\" loading=\"lazy\" />\n          ${playBtn}\n        </div>\n        <div class=\"card-body\">\n          <div class=\"reviewer-row\">\n            <span class=\"reviewer-name\">${r.reviewer}</span>\n            <span class=\"verified-badge\">${verifiedSVG()} Verifiziert</span>\n          </div>\n          <div class=\"review-date\">${r.date}</div>\n          ${starsSVG(r.rating)}\n          <div class=\"review-text\">${r.text.replace(/\\n/g, '<br>')}</div>\n          <div class=\"product-label\">Produktart:</div>\n          <div class=\"product-variant\">${r.variant}</div>\n          <div class=\"product-row\">\n            <img class=\"product-thumb\" src=\"${r.productThumb}\" alt=\"${r.product}\" />\n            <span class=\"product-name\">${r.product}</span>\n          </div>\n        </div>\n      `;\n\n      grid.appendChild(card);\n    });\n  </script>\n</body>\n</html>",
